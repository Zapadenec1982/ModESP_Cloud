NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=modesp_cloud
DB_USER=modesp_cloud
DB_PASS=

# MQTT
MQTT_URL=mqtt://localhost:1883
MQTT_USER=modesp_backend
MQTT_PASS=

# JWT (Phase 4)
JWT_SECRET=
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=2592000

# FCM / Telegram (Phase 3)
FCM_SERVER_KEY=
TELEGRAM_BOT_TOKEN=

# CORS (dev: Vite devserver)
CORS_ORIGIN=http://localhost:5173

# Tuning
TELEMETRY_INTERVAL_MS=300000
OFFLINE_THRESHOLD_MS=90000
STATE_DEBOUNCE_MS=30000
REGISTRY_REFRESH_MS=60000
