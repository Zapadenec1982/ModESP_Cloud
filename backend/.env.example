NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=modesp_cloud
DB_USER=modesp_cloud
DB_PASS=

# MQTT
MQTT_URL=mqtt://localhost:1883
MQTT_USER=modesp_backend
MQTT_PASS=

# Auth (Phase 4) — set AUTH_ENABLED=true to require JWT
AUTH_ENABLED=false
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=2592000

# Push Notifications (Phase 3)
# Telegram bot — get token from @BotFather
TELEGRAM_BOT_TOKEN=
# FCM — path to Firebase service account JSON file
FCM_SERVICE_ACCOUNT_PATH=

# MQTT Dynamic Auth (Phase 4)
# Bootstrap password shared across all ESP32 at flash time
MQTT_BOOTSTRAP_PASSWORD=
# Public hostname for devices (shown in WebUI for manual entry)
MQTT_PUBLIC_HOST=

# CORS (dev: Vite devserver)
CORS_ORIGIN=http://localhost:5173

# OTA (Phase 6)
FIRMWARE_BASE_URL=http://localhost:3000/firmware
FIRMWARE_STORAGE_PATH=./firmware
OTA_TIMEOUT_MS=600000

# Tuning
TELEMETRY_INTERVAL_MS=300000
OFFLINE_THRESHOLD_MS=90000
STATE_DEBOUNCE_MS=30000
REGISTRY_REFRESH_MS=60000
